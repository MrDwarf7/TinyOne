enum Maybe {
  None,
  Some(value)
}

enum PairState {
  Empty,
  Pair(left, right)
}

let missing = Maybe.None()
let present = Maybe.Some(42)
let pair = PairState.Pair(3, 4)

print missing
print missing.tag
print present
print present.tag
print present.value
print pair.left + pair.right
print type_of(pair)
# expect_stdout:
# Maybe.None
# 0
# Maybe.Some{value: 42}
# 1
# 42
# 7
# Enum
# end_expect_stdout
