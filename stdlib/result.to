# tinyone-stdlib/result.to
# Result variants. Tag 1 = Ok, tag 0 = Err. Aligns with typing_system.md
# §Algebraic Types (sum types). The variant payload may be any TinyOne value.

export fn ok(value) {
  return result_ok(value)
}

export fn err(value) {
  return result_err(value)
}

export fn is_ok(r) {
  return result_is_ok(r)
}

export fn is_err(r) {
  return result_is_err(r)
}

export fn unwrap(r) {
  return result_unwrap(r)
}

export fn unwrap_err(r) {
  return result_unwrap_err(r)
}
