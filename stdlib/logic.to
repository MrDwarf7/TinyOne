# tinyone-stdlib/logic.to
# Boolean logic helpers. Inputs are integers (0 or non-0) — see
# typing_system.md §Boolean Type.

export fn and(lhs, rhs) {
  return logic_and(lhs, rhs)
}

export fn or(lhs, rhs) {
  return logic_or(lhs, rhs)
}

export fn not(value) {
  return logic_not(value)
}

export fn xor(lhs, rhs) {
  return logic_xor(lhs, rhs)
}
